generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  EDITOR
  ANALYST
  VIEWER
}

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  BLACKLISTED
}

enum CampaignStatus {
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  SENDING
  PAUSED
  ACTIVE
  SENT
  COMPLETED
  CANCELLED
}

enum TriggerType {
  BIRTHDAY
  NEW_CONTACT
  CONTACT_UPDATED
  FORM_SUBMITTED
  TAG_ADDED
  CAMPAIGN_OPENED
  LINK_CLICKED
  MANUAL
  SCHEDULED
}

enum ScopeType {
  GLOBAL
  ORGANIZATION
}

enum SuppressionReason {
  UNSUBSCRIBED
  BOUNCED
  HARD_BOUNCE
  COMPLAINED
}

model Organization {
  id                String   @id @default(uuid())
  name              String
  logoUrl           String?
  brandColorPrimary String?
  customDomain      String?
  customEmailFooter String?
  
  // Stripe Billing Integration
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String            @default("FREE")
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?
  stripePriceId        String?
  trialEndsAt          DateTime?
  onboardingStep       Int               @default(1)

  users                   User[]
  memberships             Membership[]
  invites                 WorkspaceInvite[]
  contacts                Contact[]
  campaigns               Campaign[]
  tags                    Tag[]
  media                   Media[]
  automations             AutomationRule[]
  activityLogs            ActivityLog[]
  suppressionLists        SuppressionList[]
  contactAutomationStates ContactAutomationState[]
  automationLogs          AutomationLog[]
  aiUsageLogs             AiUsageLog[]
  
  aiProvider           String?
  aiApiKey             String?
  aiModelOverride      String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  role           UserRole     @default(VIEWER)
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  mfaEnabled     Boolean      @default(false)
  mfaSecret      String?
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  memberships    Membership[]
  accounts       Account[]
  sessions       Session[]
  activityLogs   ActivityLog[]
  aiUsageLogs    AiUsageLog[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contact {
  id             String       @id @default(uuid())
  email          String
  firstName      String?
  lastName       String?
  phone          String?
  city           String?
  country        String?
  birthday       DateTime?
  
  status         ContactStatus @default(ACTIVE)
  customFields   Json          @default("{}")
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  tags             Tag[]
  automationStates ContactAutomationState[]
  automationLogs   AutomationLog[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, email])
}

model Tag {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  contacts       Contact[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
}

model Campaign {
  id             String       @id @default(uuid())
  name           String
  subject        String?
  previewText    String?
  htmlContent    String?
  designContent  Json?        // GrapesJS JSON design content
  
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  
  sentCount      Int          @default(0)
  openCount      Int          @default(0)
  clickCount     Int          @default(0)
  bounceCount    Int          @default(0)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Media {
  id             String       @id @default(uuid())
  name           String
  url            String
  folder         String?
  size           Int?         // bytes
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AutomationRule {
  id             String       @id @default(uuid())
  name           String
  triggerType    TriggerType
  triggerConfig  Json?        // JSON configuration
  actions        Json?        // JSON actions
  nodes          Json?        // React Flow node graph
  edges          Json?        // React Flow edge graph
  isActive       Boolean      @default(false)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  contactStates  ContactAutomationState[]
  logs           AutomationLog[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ContactAutomationState {
  id               String         @id @default(uuid())
  contactId        String
  contact          Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  automationRuleId String
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  status           String         // "ACTIVE", "COMPLETED", "EXITED"
  currentStepId    String?
  completedSteps   Json           // array of node IDs completed
  exitReason       String?
  enteredAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  completedAt      DateTime?
  
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([contactId, automationRuleId])
}

model AutomationLog {
  id               String         @id @default(uuid())
  contactId        String
  contact          Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  automationRuleId String
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  nodeId           String
  nodeType         String
  action           String         // "ENTERED", "EXECUTED", "FAILED", "EXITED"
  details          Json?
  createdAt        DateTime       @default(now())
  
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AiUsageLog {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  feature          String       // "CAMPAIGN_WRITER", "CAMPAIGN_AUDITOR", "SEGMENT_GENERATOR", "AUTOMATION_ASSISTANT", "INSIGHTS"
  provider         String       // "OPENAI", "GEMINI"
  model            String?
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  estimatedCost    Float        @default(0.0)
  createdAt        DateTime     @default(now())
}

model ActivityLog {
  id             String       @id @default(uuid())
  action         String
  entityType     String       // "CONTACT", "CAMPAIGN", "SETTINGS"
  entityId       String?
  details        Json?        // JSON details
  
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
}

model SuppressionList {
  id             String       @id @default(uuid())
  email          String
  reason         SuppressionReason
  scope          ScopeType
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  
  @@unique([email, scope, organizationId])
}

model Membership {
  id             String       @id @default(uuid())
  role           UserRole     @default(VIEWER)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model WorkspaceInvite {
  id             String       @id @default(uuid())
  email          String
  role           UserRole     @default(VIEWER)
  token          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@unique([organizationId, email])
}
